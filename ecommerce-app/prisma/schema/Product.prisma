model Product {
  id         String           @id @default(uuid())
  price      Float
  quantity   Int
  category   Category         @relation(fields: [categoryId], references: [id])
  categoryId String
  brand      Brand            @relation(fields: [brandId], references: [id])
  brandId    String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  tags       ProductsOnTags[]
}
