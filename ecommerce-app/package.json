{
  "name": "ecommerce-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "cd .. && husky ecommerce-app/.husky",
    "scaffold:route": "NODE_OPTIONS='--experimental-strip-types' node ./scripts/api-route-scaffold/index.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma": "npx prisma",
    "prisma:migrate:create": "npx prisma migrate dev",
    "prisma:migrate:run": "npx prisma migrate deploy",
    "prisma:migrate:drop": "npx prisma migrate reset",
    "prisma:migrate:push": "npx prisma db push",
    "prisma:check": "npx prisma format --check",
    "prisma:format": "npx prisma format",
    "format": "NODE_OPTIONS='--experimental-strip-types' prettier . --write",
    "format:ci": "NODE_OPTIONS='--experimental-strip-types' prettier . --check",
    "docker": "docker-compose -f docker-compose.yml up --build",
    "docker:dev": "docker-compose -f docker-compose.yml up"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "@sanity/client": "^6.28.0",
    "firebase": "^11.3.0",
    "next": "15.1.6",
    "next-firebase-auth-edge": "^1.8.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/nesting": "^0.0.0-insiders.565cd3e",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "daisyui": "^4.12.23",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "eslint-config-prettier": "^10.0.1",
    "handlebars": "^4.7.8",
    "husky": "^9.1.7",
    "inquirer": "^12.4.2",
    "lint-staged": "^15.4.3",
    "postcss": "^8",
    "postcss-import": "^16.1.0",
    "prettier": "3.5.0",
    "prettier-plugin-css-order": "^2.1.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "packageManager": "yarn@4.6.0",
  "volta": {
    "node": "22.13.1",
    "yarn": "4.6.0"
  }
}
